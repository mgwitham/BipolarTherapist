VITE_SANITY_PROJECT_ID=your-project-id
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2026-04-02
VITE_SANITY_USE_CDN=true
VITE_SANITY_STUDIO_URL=http://localhost:3333
VITE_REVIEW_API_URL=http://localhost:8787
REVIEW_API_PORT=8787
REVIEW_API_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REVIEW_API_SESSION_TTL_MS=43200000
REVIEW_API_LOGIN_WINDOW_MS=900000
REVIEW_API_LOGIN_MAX_ATTEMPTS=10
# Keep this only in your local .env, never in git.
SANITY_API_TOKEN=
REVIEW_API_ADMIN_USERNAME=
REVIEW_API_ADMIN_PASSWORD=
REVIEW_API_SESSION_SECRET=
# Global kill switch for all automated/transactional email that flows
# through server/review-email.mjs sendEmail() — weekly digest, license
# warnings, recovery flows, portal nudges, etc. Set to "true" to halt
# all of them at once. Does NOT affect manual outreach sends from the
# CRM (/api/admin/send-email uses a separate code path).
EMAIL_KILL_SWITCH=
RESEND_API_KEY=
REVIEW_EMAIL_FROM=
REVIEW_NOTIFICATION_TO=
# Outreach CRM — From: address for emails sent via /outreach.html.
# If unset, falls back to REVIEW_EMAIL_FROM.
OUTREACH_EMAIL_FROM=
# Optional: where the "Send test to me" button delivers. If unset,
# tests go to the bare email address parsed out of OUTREACH_EMAIL_FROM.
OUTREACH_TEST_TO=
# CAN-SPAM compliance: every commercial email must include a valid
# physical postal address. The /api/admin/send-email endpoint refuses
# to send when this is unset. Use a PO Box or virtual mailbox if you
# don't want your home address in cold emails.
OUTREACH_FOOTER_ADDRESS=
# Optional: org name shown in the email footer (default: BipolarTherapyHub).
OUTREACH_FOOTER_ORG_NAME=
# Resend webhook signing secret (starts with `whsec_`). Set this after
# creating the webhook in the Resend dashboard. The
# /api/review/webhooks/resend endpoint refuses unsigned payloads;
# without this var it returns 503.
RESEND_WEBHOOK_SECRET=
# DEV-ONLY safety valve. When set, every email sent through Resend gets
# redirected to this single inbox regardless of the original recipient.
# Pair with a Gmail "+" alias for filtering, e.g.
#   EMAIL_DEV_REDIRECT=you+bth-dev@gmail.com
# NEVER set this in production — the server refuses to honor it when
# NODE_ENV=production and logs a critical warning. The /dev/emails
# preview UI also shows a banner reminding you when the redirect is active.
EMAIL_DEV_REDIRECT=
# DCA License Verification API (register at https://iservices.dca.ca.gov)
DCA_APP_ID=
DCA_APP_KEY=
# Stripe (test keys locally, live keys in production only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Canonical price ID for the $19/month paid tier (single-tier pricing
# model from PR #172). Set this to the Stripe price you created. If
# unset, the server falls back to STRIPE_FEATURED_PRICE_ID.
STRIPE_PAID_MONTHLY_PRICE_ID=
# Legacy fallback — used when STRIPE_PAID_MONTHLY_PRICE_ID is unset.
STRIPE_FEATURED_PRICE_ID=
STRIPE_TRIAL_DAYS=14
STRIPE_RETURN_URL_BASE=https://www.bipolartherapyhub.com
# Dev-only portal login bypass. Leave unset (or false) everywhere except
# a local dev machine. The server also requires NODE_ENV=development and
# a hardcoded email allowlist before the bypass will work. NEVER set this
# in production or any shared environment.
ALLOW_DEV_LOGIN=false
# Sentry error tracking (https://sentry.io)
# Create a project, then add the DSN here. Both vars use the same DSN —
# SENTRY_DSN is read server-side; VITE_SENTRY_DSN is bundled into the browser build.
# Leave blank locally unless you want to send dev errors to Sentry.
SENTRY_DSN=
VITE_SENTRY_DSN=
# Cloudflare Turnstile (anti-bot captcha on signup / claim / recover /
# remove forms). Optional — when either key is unset, the integration
# is fully no-op (no widget shown, server skips verification). To
# enable: dash.cloudflare.com -> Turnstile -> Add Site, Managed mode,
# domain bipolartherapyhub.com. Set BOTH keys (site key is public,
# secret key is server-only). Cloudflare offers test keys for local
# dev; see https://developers.cloudflare.com/turnstile/troubleshooting/testing/
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# PostHog product analytics (session recordings + heatmaps + autocapture)
# on patient-facing pages (index, match, results, directory, therapist).
# Optional — when VITE_POSTHOG_KEY is unset, the SDK is never loaded.
# To enable: posthog.com -> create project (free tier: 1M events/mo +
# 5k session recordings/mo). Copy the Project API Key (starts with phc_)
# into VITE_POSTHOG_KEY. Default host is US; override for EU region.
# Honors DNT and Global Privacy Control; masks input values in recordings.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
