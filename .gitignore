.DS_Store
node_modules/
dist/
studio/node_modules/
studio/.sanity/
studio/dist/
.env
studio/.env
tmp/
*.log
coverage/
.lighthouserc.generated.json
playwright-report/
test-results/
data/import/*.csv
data/import/generated-*.csv
data/import/generated-*.md
data/import/generated-*.json
# Outreach draft packet — contains real therapist PII, not a durable record.
data/import/CALIFORNIA_PRIORITY_CONFIRMATION_DRAFTS.md
data/import/email-discovery-response.json
data/import/email-discovery-batch-*.json
# Demand-side referral contact batches — contact PII, not durable records.
# (The committed referral-contacts.example.json template has a dot, not a dash,
# so it is intentionally NOT matched by this pattern.)
data/import/referral-contacts-*.json
!data/import/therapists-template.csv
!data/import/therapist-candidates-template.csv
!data/import/therapist-source-seeds-template.csv
# Directory-wide evidence audits. These are durable operating records of a
# removal decision, not disposable working output, so they are tracked per
# docs/DATA_ARTIFACT_POLICY.md. Re-running the audit later would produce
# different results as clinicians edit their public profiles.
!data/import/bipolar-evidence-audit-*.csv
scripts/*-ingest-batch-*.json

# Audit / report output — see scripts/audit-ghost-candidates.mjs and friends
scripts/reports/

# Generated at build time — see scripts/generate-sitemap.mjs
public/sitemap.xml
.vercel

# Claude Code local worktrees — embedded git checkouts, not content
.claude/worktrees/
.claude/scheduled_tasks.lock

# Sanity dataset exports — local backups, not content
backups/

# Lighthouse CI local run artifacts
.lighthouseci/
