{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "functions": {
    "api/therapists/[slug].mjs": {
      "includeFiles": "dist/therapist.html"
    }
  },
  "redirects": [
    {
      "source": "/therapist.html",
      "has": [{ "type": "query", "key": "slug", "value": "(?<slug>.+)" }],
      "destination": "/therapists/:slug",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/review/(.*)", "destination": "/api/review/[...path]" },
    { "source": "/therapists/:slug", "destination": "/api/therapists/:slug" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/founder-digest",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/dca-freshness",
      "schedule": "0 9 * * 2"
    },
    {
      "path": "/api/cron/license-expiration-warnings",
      "schedule": "0 16 * * *"
    }
  ]
}
