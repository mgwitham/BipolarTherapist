{
  "name": "bipolar-therapist-directory",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "BipolarTherapyHub local product workspace for guided bipolar-specialist discovery, matching, and therapist onboarding.",
  "scripts": {
    "dev": "vite",
    "api:dev": "NODE_ENV=development node server/review-api.mjs",
    "build": "npm run build:sitemap && vite build && npm run build:seo-pages",
    "build:sitemap": "node scripts/generate-sitemap.mjs",
    "build:seo-pages": "node scripts/generate-seo-profile-pages.mjs",
    "preview": "vite preview",
    "cms:dev": "npm --prefix studio run dev",
    "cms:build": "npm --prefix studio run build",
    "cms:check:therapists": "node scripts/check-therapist-import-readiness.mjs",
    "cms:check:therapists:strict": "node scripts/check-therapist-import-readiness.mjs --max-strong-warnings=0",
    "cms:check:therapists:write": "node scripts/check-therapist-import-readiness.mjs --write-queue=data/import/generated-import-warning-queue.csv",
    "cms:generate:confirmation-batch": "npm run cms:check:therapists:write && node scripts/generate-therapist-confirmation-batch.mjs",
    "cms:generate:confirmation-sprint": "npm run cms:generate:confirmation-batch && node scripts/generate-confirmation-sprint.mjs",
    "cms:generate:profile-conversion-sprint": "npm run cms:generate:confirmation-batch && node scripts/generate-profile-conversion-sprint.mjs",
    "cms:generate:profile-conversion-outreach": "npm run cms:generate:profile-conversion-sprint && node scripts/generate-profile-conversion-outreach.mjs",
    "cms:generate:profile-conversion-send-sheet": "npm run cms:generate:profile-conversion-outreach && node scripts/generate-profile-conversion-send-sheet.mjs",
    "cms:generate:profile-conversion-tracker": "npm run cms:generate:profile-conversion-outreach && node scripts/generate-profile-conversion-tracker.mjs",
    "cms:generate:profile-conversion-response-sheet": "npm run cms:generate:profile-conversion-tracker && node scripts/generate-profile-conversion-response-sheet.mjs",
    "cms:sync:profile-conversion-tracker": "node scripts/sync-profile-conversion-tracker.mjs",
    "cms:apply:profile-conversion-responses": "node scripts/apply-profile-conversion-responses.mjs",
    "cms:summarize:profile-conversion-status": "node scripts/summarize-profile-conversion-status.mjs",
    "cms:mark:profile-conversion-sent": "node scripts/mark-profile-conversion-sent.mjs",
    "cms:mark:profile-conversion-replied": "node scripts/mark-profile-conversion-replied.mjs",
    "cms:generate:profile-conversion-command-sheet": "node scripts/generate-profile-conversion-command-sheet.mjs",
    "cms:generate:profile-conversion-freshness-queue": "npm run cms:generate:profile-conversion-sprint && node scripts/generate-profile-conversion-freshness-queue.mjs",
    "cms:generate:import-blocker-sprint": "npm run cms:generate:confirmation-batch && node scripts/generate-import-blocker-sprint.mjs",
    "cms:generate:overlapping-ask-packet": "npm run cms:generate:confirmation-batch && node scripts/generate-overlapping-ask-packet.mjs",
    "cms:generate:top-outreach-wave": "npm run cms:generate:overlapping-ask-packet && node scripts/generate-top-outreach-wave.mjs",
    "cms:generate:top-outreach-send-sheet": "npm run cms:generate:top-outreach-wave && node scripts/generate-top-outreach-send-sheet.mjs",
    "cms:generate:top-outreach-drafts": "npm run cms:generate:top-outreach-wave && node scripts/generate-top-outreach-drafts.mjs",
    "cms:generate:top-outreach-tracker": "npm run cms:generate:top-outreach-wave && node scripts/generate-top-outreach-tracker.mjs",
    "cms:generate:top-outreach-session": "npm run cms:generate:top-outreach-wave && node scripts/generate-top-outreach-session.mjs",
    "cms:generate:california-priority-shared-ask": "node scripts/generate-california-priority-shared-ask.mjs",
    "cms:check:confirmation-responses": "node scripts/check-confirmation-responses.mjs",
    "cms:apply:confirmation-responses": "node scripts/apply-confirmation-responses.mjs",
    "cms:apply:confirmation-safe": "npm run cms:check:confirmation-responses && npm run cms:apply:confirmation-responses && npm run lint && npm run build",
    "cms:discover:candidates": "node scripts/discover-therapist-candidates.mjs",
    "cms:import:candidates": "node scripts/import-therapist-candidates.mjs",
    "cms:generate:candidate-review-queue": "node scripts/generate-candidate-review-queue.mjs",
    "cms:generate:ingestion-ops-queue": "node scripts/generate-ingestion-ops-queue.mjs",
    "cms:run:source-health-checks": "node scripts/run-source-health-checks.mjs",
    "cms:run:operational-drift-checks": "node scripts/run-operational-drift-checks.mjs",
    "cms:run:auto-source-review": "node scripts/run-auto-source-review.mjs",
    "cms:generate:source-domain-health-report": "node scripts/generate-source-domain-health-report.mjs",
    "cms:generate:provider-field-observations-preview": "node scripts/generate-provider-field-observations-preview.mjs",
    "cms:generate:provider-id-backfill-preview": "node scripts/generate-provider-id-backfill-preview.mjs",
    "cms:generate:provider-id-consistency-report": "node scripts/generate-provider-id-consistency-report.mjs",
    "cms:generate:provider-id-diagnostics": "node scripts/generate-provider-id-diagnostics.mjs",
    "cms:inspect:provider-observations": "node scripts/inspect-provider-observations.mjs",
    "cms:export:provider-observations": "node scripts/export-provider-observations.mjs",
    "cms:inspect:match-requests": "node scripts/inspect-match-requests.mjs",
    "cms:inspect:match-outcomes": "node scripts/inspect-match-outcomes.mjs",
    "cms:export:match-requests": "node scripts/export-match-requests.mjs",
    "cms:export:match-outcomes": "node scripts/export-match-outcomes.mjs",
    "cms:summarize:match-learning": "node scripts/summarize-match-learning.mjs",
    "cms:summarize:provider-observations": "node scripts/summarize-provider-observations.mjs",
    "cms:summarize:data-substrate": "node scripts/summarize-data-substrate.mjs",
    "cms:smoke:match-persistence": "node scripts/smoke-match-persistence.mjs",
    "cms:smoke:match-persistence:cleanup": "node scripts/smoke-match-persistence.mjs --cleanup",
    "cms:generate:sourcing-recommendations": "node scripts/generate-sourcing-recommendations.mjs",
    "cms:generate:licensure-refresh-queue": "node scripts/generate-licensure-refresh-queue.mjs",
    "cms:generate:licensure-activity-feed": "node scripts/generate-licensure-activity-feed.mjs",
    "cms:generate:reverification-batch": "node scripts/generate-reverification-batch.mjs",
    "cms:generate:ops-session": "node scripts/generate-ops-session.mjs",
    "cms:run:ingestion-automation": "node scripts/run-ingestion-automation.mjs",
    "cms:enrich:california-licensure": "node scripts/enrich-california-licensure.mjs",
    "cms:discovery-prompt": "node scripts/generate-discovery-prompt.mjs",
    "cms:verify-licenses": "node scripts/verify-candidate-licenses.mjs",
    "cms:rejection-report": "node scripts/report-rejection-patterns.mjs",
    "cms:get-more-therapists": "node scripts/get-more-therapists.mjs",
    "cms:ingest": "node scripts/run-pilot-ingestion.mjs",
    "cms:import:therapists:safe": "npm run cms:check:therapists:strict && node scripts/import-therapists.mjs",
    "cms:import:therapists": "node scripts/import-therapists.mjs",
    "test": "node --test \"test/**/*.test.mjs\"",
    "lint": "eslint .",
    "smoke:top-flows": "npm run build && node scripts/smoke-top-flows.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run build && npm run cms:build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md,yml,yaml}": "prettier --write"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@sanity/client": "^7.21.0",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@vercel/analytics": "^2.0.1",
    "stripe": "^22.0.2"
  }
}
