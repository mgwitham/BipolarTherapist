{
  "name": "bipolar-therapist-directory",
  "private": true,
  "version": "1.0.0",
  "description": "BipolarTherapyHub local product workspace for guided bipolar-specialist discovery, matching, and therapist onboarding.",
  "scripts": {
    "dev": "vite",
    "api:dev": "node server/review-api.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "cms:dev": "npm --prefix studio run dev",
    "cms:build": "npm --prefix studio run build",
    "cms:check:therapists": "node scripts/check-therapist-import-readiness.mjs",
    "cms:check:therapists:strict": "node scripts/check-therapist-import-readiness.mjs --max-strong-warnings=0",
    "cms:check:therapists:write": "node scripts/check-therapist-import-readiness.mjs --write-queue=data/import/generated-import-warning-queue.csv",
    "cms:generate:confirmation-batch": "npm run cms:check:therapists:write && node scripts/generate-therapist-confirmation-batch.mjs",
    "cms:generate:confirmation-sprint": "npm run cms:generate:confirmation-batch && node scripts/generate-confirmation-sprint.mjs",
    "cms:generate:import-blocker-sprint": "npm run cms:generate:confirmation-batch && node scripts/generate-import-blocker-sprint.mjs",
    "cms:generate:overlapping-ask-packet": "npm run cms:generate:confirmation-batch && node scripts/generate-overlapping-ask-packet.mjs",
    "cms:generate:top-outreach-wave": "npm run cms:generate:overlapping-ask-packet && node scripts/generate-top-outreach-wave.mjs",
    "cms:generate:top-outreach-send-sheet": "npm run cms:generate:top-outreach-wave && node scripts/generate-top-outreach-send-sheet.mjs",
    "cms:generate:top-outreach-drafts": "npm run cms:generate:top-outreach-wave && node scripts/generate-top-outreach-drafts.mjs",
    "cms:generate:top-outreach-tracker": "npm run cms:generate:top-outreach-wave && node scripts/generate-top-outreach-tracker.mjs",
    "cms:generate:top-outreach-session": "npm run cms:generate:top-outreach-wave && node scripts/generate-top-outreach-session.mjs",
    "cms:generate:california-priority-shared-ask": "node scripts/generate-california-priority-shared-ask.mjs",
    "cms:update:launch-controls": "node scripts/update-launch-profile-controls.mjs",
    "cms:check:confirmation-responses": "node scripts/check-confirmation-responses.mjs",
    "cms:apply:confirmation-responses": "node scripts/apply-confirmation-responses.mjs",
    "cms:apply:confirmation-safe": "npm run cms:check:confirmation-responses && npm run cms:apply:confirmation-responses && npm run lint && npm run build",
    "cms:discover:candidates": "node scripts/discover-therapist-candidates.mjs",
    "cms:import:candidates": "node scripts/import-therapist-candidates.mjs",
    "cms:generate:candidate-review-queue": "node scripts/generate-candidate-review-queue.mjs",
    "cms:generate:ingestion-ops-queue": "node scripts/generate-ingestion-ops-queue.mjs",
    "cms:run:source-health-checks": "node scripts/run-source-health-checks.mjs",
    "cms:run:operational-drift-checks": "node scripts/run-operational-drift-checks.mjs",
    "cms:generate:source-domain-health-report": "node scripts/generate-source-domain-health-report.mjs",
    "cms:generate:reverification-batch": "node scripts/generate-reverification-batch.mjs",
    "cms:generate:ops-session": "node scripts/generate-ops-session.mjs",
    "cms:get-more-therapists": "node scripts/get-more-therapists.mjs",
    "cms:import:therapists:safe": "npm run cms:check:therapists:strict && node scripts/import-therapists.mjs",
    "cms:import:therapists": "node scripts/import-therapists.mjs",
    "lint": "eslint .",
    "smoke:top-flows": "npm run build && node scripts/smoke-top-flows.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run build && npm run cms:build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md,yml,yaml}": "prettier --write"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@sanity/client": "^7.11.1",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "vite": "^8.0.3"
  }
}
